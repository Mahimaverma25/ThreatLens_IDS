NODE_ENV=development
PORT=5000
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.mongodb.net/threatlens
JWT_SECRET=change-this-access-secret
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=change-this-refresh-secret
REFRESH_TOKEN_EXPIRES_IN=30d
REFRESH_COOKIE_NAME=threatlens_rt
REFRESH_COOKIE_SECURE=false
REFRESH_COOKIE_SAMESITE=lax
FRONTEND_BASE_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000
IDS_ENGINE_URL=http://localhost:8000
ENABLE_IDS_ANALYSIS=true
ENABLE_DEMO_TELEMETRY=false
ALLOW_SYNTHETIC_TRAFFIC=false
INTEGRATION_API_KEY=
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=1000
AUTH_RATE_LIMIT_MAX=15
BODY_LIMIT=1mb
ALERT_CORRELATION_WINDOW_MINS=10
DOS_THRESHOLD_PER_MINUTE=150
BRUTE_FORCE_THRESHOLD=5
INGEST_BATCH_LIMIT=500
INGEST_SIGNATURE_TOLERANCE_MS=300000
LOG_LEVEL=info
