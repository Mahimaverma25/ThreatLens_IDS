NODE_ENV=development
PORT=5001
MONGO_URI=mongodb://127.0.0.1:27017/threatlens
JWT_SECRET=replace-with-64-plus-random-hex-access-secret
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=replace-with-64-plus-random-hex-refresh-secret
REFRESH_TOKEN_EXPIRES_IN=30d
REFRESH_COOKIE_NAME=threatlens_rt
REFRESH_COOKIE_SECURE=false
REFRESH_COOKIE_SAMESITE=lax
FRONTEND_BASE_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000
IDS_ENGINE_URL=http://localhost:8000
ENABLE_IDS_ANALYSIS=true
ENABLE_DEMO_TELEMETRY=false
ALLOW_SYNTHETIC_TRAFFIC=false
INTEGRATION_API_KEY=replace-with-32-plus-random-hex-ids-engine-key
REDIS_URL=redis://127.0.0.1:6379
REDIS_STREAM_KEY=threatlens:events
REDIS_STREAM_MAXLEN=2000
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=1000
AUTH_RATE_LIMIT_MAX=15
AGENT_RATE_LIMIT_MAX=300
BODY_LIMIT=1mb
UPLOAD_BODY_LIMIT=20mb
MAX_UPLOAD_FILE_SIZE_BYTES=20971520
ALERT_CORRELATION_WINDOW_MINS=10
DOS_THRESHOLD_PER_MINUTE=150
BRUTE_FORCE_THRESHOLD=5
INGEST_BATCH_LIMIT=500
INGEST_SIGNATURE_TOLERANCE_MS=300000
INGEST_NONCE_TTL_MS=600000
LOG_LEVEL=info
