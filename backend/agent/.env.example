# ThreatLens Agent Configuration

# Backend API Configuration
# Windows host backend URL from WSL usually uses the default gateway IP, not localhost.
THREATLENS_API_URL=http://172.31.208.1:5000
THREATLENS_API_KEY=your-api-token-here
THREATLENS_API_SECRET=your-api-secret-here

# Asset & Organization Info
ASSET_ID=agent-001

# Agent mode
AGENT_MODE=snort

# Live Snort log files
# Windows example:
# SNORT_FAST_LOG_PATH=C:\snort\log\alert_fast.txt
# SNORT_EVE_JSON_PATH=C:\snort\log\eve.json
#
# WSL/Linux example:
SNORT_FAST_LOG_PATH=/var/log/snort/snort.alert.fast
SNORT_EVE_JSON_PATH=/var/log/snort/eve.json

# Event Buffering
BATCH_SIZE=20
BATCH_TIMEOUT_MS=5000
FILE_DISCOVERY_INTERVAL_MS=10000
MAX_BUFFER_SIZE=5000
MAX_RETRIES=3
RETRY_DELAY_MS=1500

# Health Check Interval
HEALTH_CHECK_INTERVAL_MS=60000

# Logging
LOG_LEVEL=info
