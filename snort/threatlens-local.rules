alert icmp any any -> any any (
    msg:"ThreatLens ICMP Echo Activity";
    itype:8;
    classtype:misc-activity;
    priority:3;
    sid:1001001;
    rev:1;
)

alert tcp any any -> any 80 (
    msg:"ThreatLens HTTP Admin Access Probe";
    flow:to_server,established;
    content:"/admin";
    nocase;
    classtype:web-application-attack;
    priority:2;
    sid:1001002;
    rev:1;
)

alert tcp any any -> any 80 (
    msg:"ThreatLens SQL Injection Probe";
    flow:to_server,established;
    content:"union";
    nocase;
    content:"select";
    nocase;
    distance:0;
    within:32;
    classtype:web-application-attack;
    priority:1;
    sid:1001003;
    rev:1;
)

alert tcp any any -> any [80,8080,443] (
    msg:"ThreatLens XSS Attempt Probe";
    flow:to_server,established;
    content:"<script";
    nocase;
    classtype:web-application-attack;
    priority:1;
    sid:1001008;
    rev:1;
)

alert tcp any any -> any [80,8080,443] (
    msg:"ThreatLens Directory Traversal Probe";
    flow:to_server,established;
    content:"../";
    nocase;
    classtype:web-application-attack;
    priority:1;
    sid:1001009;
    rev:1;
)

alert tcp any any -> any [80,8080,443] (
    msg:"ThreatLens Remote Code Execution Probe";
    flow:to_server,established;
    pcre:"/(cmd=|powershell|\/bin\/sh|wget\x20|curl\x20)/Ui";
    classtype:web-application-attack;
    priority:1;
    sid:1001010;
    rev:1;
)

alert tcp any any -> any 22 (
    msg:"ThreatLens SSH Access Probe";
    flags:S;
    classtype:attempted-recon;
    priority:2;
    sid:1001004;
    rev:1;
)

alert tcp any any -> any 445 (
    msg:"ThreatLens SMB Lateral Movement Probe";
    flags:S;
    classtype:attempted-admin;
    priority:1;
    sid:1001005;
    rev:1;
)

alert udp any any -> any 53 (
    msg:"ThreatLens DNS Tunnel Keyword";
    content:"threatlens-tunnel";
    nocase;
    classtype:bad-unknown;
    priority:2;
    sid:1001006;
    rev:1;
)

alert tcp any any -> any 3389 (
    msg:"ThreatLens RDP Burst Probe";
    flags:S;
    classtype:attempted-recon;
    priority:2;
    sid:1001007;
    rev:1;
)

alert tcp any any -> any 21 (
    msg:"ThreatLens FTP Anonymous Login Probe";
    flow:to_server,established;
    content:"anonymous";
    nocase;
    classtype:attempted-recon;
    priority:2;
    sid:1001011;
    rev:1;
)

alert tcp any any -> any 23 (
    msg:"ThreatLens Telnet Exposure Probe";
    flags:S;
    classtype:attempted-admin;
    priority:1;
    sid:1001012;
    rev:1;
)

alert udp any any -> any 123 (
    msg:"ThreatLens NTP Amplification Probe";
    content:"|17 00 03 2a|";
    depth:4;
    classtype:attempted-dos;
    priority:1;
    sid:1001013;
    rev:1;
)

alert tcp any any -> any 389 (
    msg:"ThreatLens LDAP Enumeration Probe";
    flags:S;
    classtype:attempted-recon;
    priority:2;
    sid:1001014;
    rev:1;
)

alert tcp any any -> any 25 (
    msg:"ThreatLens Suspicious SMTP Relay Probe";
    flow:to_server,established;
    content:"RCPT TO:";
    nocase;
    classtype:misc-activity;
    priority:2;
    sid:1001015;
    rev:1;
)

alert tcp any any -> any [443,8443] (
    msg:"ThreatLens Malware Beacon Keyword";
    flow:to_server,established;
    content:"beacon";
    nocase;
    classtype:trojan-activity;
    priority:1;
    sid:1001016;
    rev:1;
)
